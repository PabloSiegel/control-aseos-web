# Copia este archivo como .env y rellena los valores
# NO subas .env a GitHub (está en .gitignore)

# ID del Google Sheet (lo que aparece en la URL: /spreadsheets/d/ESTE_ID/edit)
SHEET_ID=1Kf1mEOQ1sQUUD1N6pOlexz0mqBecIuo2aVUyllT9nrU

# Contenido completo del JSON de la Service Account de Google
# (el archivo que descargas desde Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# Puerto (Render lo sobreescribe automáticamente)
PORT=3000
